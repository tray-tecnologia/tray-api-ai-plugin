{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Customer",
  "description": "Payload de atualização parcial de cliente via PUT /customers/:id. Doc: https://developers.tray.com.br/#api-de-clientes",
  "type": "object",
  "properties": {
    "name": { "type": "string", "maxLength": 255 },
    "email": { "type": "string", "format": "email" },
    "cpf": { "type": "string", "format": "cpf" },
    "cnpj": { "type": "string", "format": "cnpj" },
    "gender": { "type": "string", "enum": ["M", "F"] },
    "birth_date": { "type": "string", "format": "date" },
    "phone": { "type": "string" },
    "newsletter": { "type": "integer", "enum": [0, 1] }
  },
  "additionalProperties": false
}
